// Prisma Schema for Aura — AI Trading Card Scanner & Collection Platform
// =======================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Authentication (NextAuth compatible) ───────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  role          String    @default("USER")
  plan          String    @default("FREE")
  scansToday    Int       @default(0)
  scansResetAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  passwordHash  String?

  accounts       Account[]
  sessions       Session[]
  collections    Collection[]
  scanHistory    ScanHistory[]
  watchlist      Watchlist[]
  notifications  Notification[]
  folders        Folder[]
  decks          Deck[]
  portfolioSnapshots PortfolioSnapshot[]
  captureRejections  CaptureRejection[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Enums (N/A in SQLite, mapped to strings) ─────────────────────────


// ─── Cards ──────────────────────────────────────────────────────────

model Card {
  id             String   @id @default(cuid())
  externalId     String?  @unique // TCGPlayer/Scryfall/YGOPro ID
  name           String
  game           String
  setName        String
  setCode        String?
  collectorNumber String?
  rarity         String   @default("COMMON")
  imageUrl       String?
  thumbnailUrl   String?
  artist         String?
  description    String?
  types          String? // e.g., "Fire,Stage 2" or "Creature,Dragon"
  supertypes     String? // e.g., "Pokémon,Legendary"
  subtypes       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  prices          CardPrice?
  priceHistory    PriceHistory[]
  collectionCards CollectionCard[]
  scanHistory     ScanHistory[]
  watchlist       Watchlist[]
  recognitionMemory RecognitionMemory[]

  @@index([name])
  @@index([game])
  @@index([setCode])
  @@index([game, setCode, collectorNumber])
  @@map("cards")
}

model CardPrice {
  id            String   @id @default(cuid())
  cardId        String   @unique
  marketPrice   Float?
  lowPrice      Float?
  midPrice      Float?
  highPrice     Float?
  foilPrice     Float?
  currency      String   @default("USD")
  source        String   @default("tcgplayer") // tcgplayer, scryfall, ygoprodeck
  lastUpdated   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_prices")
}

model PriceHistory {
  id          String   @id @default(cuid())
  cardId      String
  marketPrice Float?
  lowPrice    Float?
  midPrice    Float?
  highPrice   Float?
  recordedAt  DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, recordedAt])
  @@map("price_history")
}

// ─── Collections ────────────────────────────────────────────────────

model Collection {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("My Collection")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards CollectionCard[]

  @@map("collections")
}

model CollectionCard {
  id           String   @id @default(cuid())
  collectionId String
  cardId       String
  quantity     Int      @default(1)
  condition    String?  // NM, LP, MP, HP, DMG
  notes        String?
  addedAt      DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  card       Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([collectionId, cardId])
  @@map("collection_cards")
}

// ─── Scan History ───────────────────────────────────────────────────

model ScanHistory {
  id             String   @id @default(cuid())
  userId         String
  cardId         String?
  imageUrl       String?  // S3 URL of scanned image
  ocrText        String?
  confidence     Float?
  matchMethod    String?  // ocr, image, hybrid
  processingTime Int?     // milliseconds
  createdAt      DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("scan_history")
}

// ─── Capture Rejections ─────────────────────────────────────────────
// One row per frame the client-side quality gate declined (Phase 5.14.3).
//
// A rejected frame is NOT a scan: no image was uploaded, no OCR call was spent,
// no card database was consulted. It therefore does not belong in ScanHistory —
// `prisma.scanHistory.count()` backs the admin "Total Scans" tile, and padding a
// real number with non-scans would fabricate a measurement by contamination.
// Separate table, separate question: "how often does capture block a scan
// before the pipeline even starts, and why?"
//
// Every column is a direct measurement. `reason` is the gate's own verdict from
// CAPTURE_FAILURE_REASONS; there is no derived "quality score" and no judgement
// about the card or the user. Rows are written best-effort by the client — a
// dropped report is a missing measurement, never an inferred one.

model CaptureRejection {
  id        String   @id @default(cuid())
  userId    String
  // One of CAPTURE_FAILURE_REASONS (capture-rejection.ts) — validated at the
  // route boundary, so an unknown value is rejected rather than stored.
  reason    String
  // One of CAPTURE_MODES: manual | smart | auto. Null when the client didn't
  // say — unknown, not assumed.
  mode      String?
  // The game filter active in the UI, or null for "All". Not the card's game:
  // no card was ever read, so that is unknowable here.
  game      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("capture_rejections")
}

// ─── Recognition Memory (Phase 5.18) ────────────────────────────────
// Aura's durable memory of card identities it has ALREADY verified. One row is
// written ONLY after the Decision Gate accepts a scan — never for a rejected,
// ambiguous, or guessed candidate, and never straight from a provider response
// that has not passed the truth boundary. Existence of a row therefore means
// exactly one thing: "Aura deterministically identified this card, and stands
// behind it." That is the same bar `persistPrinting` already meets, recorded
// here as an addressable identity so a future scan can consult Aura's own
// memory before asking an external provider.
//
// This does NOT replace the provider truth boundary — it records its verdicts.
// Unknown cards (no row) still go through full provider discovery unchanged.
//
// `lookupKey` is a deterministic function of the OCR-derived identity (game +
// set/collector for set-CN games, game + name otherwise), computed identically
// at write and read time (recognition-memory.ts). It is unique so re-verifying
// the same identity refreshes one row rather than accumulating duplicates. The
// discrete normalized columns are kept alongside it for the name-key fallback
// query and for honest, queryable telemetry.

model RecognitionMemory {
  id                 String   @id @default(cuid())
  // Deterministic identity key — the primary lookup path. Unique: one verified
  // identity, one row.
  lookupKey          String   @unique
  game               String
  nameKey            String   // normalized card name (lowercased, ws-collapsed)
  setCodeKey         String?  // normalized set code; null when keyed by name
  collectorNumberKey String?  // normalized collector-number prefix; null likewise
  // The canonical, authoritative printing this identity resolves to. Points at
  // the same global Card row persistPrinting wrote on accept — the printing is
  // rebuilt from here on a memory hit, so serving never touches a provider.
  cardId             String
  externalId         String   // denormalized canonical id (integrity + telemetry)
  cardName           String   // human-readable, for logs
  // Verdict metadata from the accept that created/refreshed this memory.
  verificationState  String   @default("VERIFIED")
  method             String   // the MatchMethod that produced the accept
  confidence         Int      // 0–100, the accepted confidence
  signals            String?  // JSON: evidence summary at verification time
  timesServed        Int      @default(0) // how often memory answered for this id
  verifiedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([game, nameKey])
  @@map("recognition_memory")
}

// ─── Watchlist ──────────────────────────────────────────────────────

model Watchlist {
  id             String   @id @default(cuid())
  userId         String
  cardId         String
  alertAbove     Float?   // notify if price goes above this
  alertBelow     Float?   // notify if price drops below this
  alertEnabled   Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@map("watchlist")
}

// ─── Notifications ──────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // price_alert, system, info
  read      Boolean  @default(false)
  data      String?  // additional metadata (JSON serialized string)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ─── Organization ───────────────────────────────────────────────────

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent Folder? @relation("FolderToFolder", fields: [parentId], references: [id])
  children Folder[] @relation("FolderToFolder")

  @@map("folders")
}

model Deck {
  id        String   @id @default(cuid())
  userId    String
  name      String
  game      String
  format    String?  // Standard, Commander, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("decks")
}

// ─── Portfolio Snapshots ────────────────────────────────────────────
// One real, recorded snapshot of a user's total collection value per day.
// Written opportunistically when the user views Insights (idempotent per
// UTC day) and by the price-update cron. This is the ONLY source of the
// portfolio-over-time chart — no value shown to the user is ever synthesized.
// Until at least two days accumulate, Insights shows a "building history"
// state rather than inventing a trend line.

model PortfolioSnapshot {
  id         String   @id @default(cuid())
  userId     String
  totalValue Float    @default(0)
  cardCount  Int      @default(0)
  recordedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@map("portfolio_snapshots")
}

// ─── AI Learning Rules ───────────────────────────────────────────────
// Auto-generated rules based on scan history analysis.
// When the AI repeatedly struggles with a card, a rule is created and
// injected into the AI prompt during future scans of that card.

model AiLearningRule {
  id           String   @id @default(cuid())
  // The card name or game this rule targets (e.g., "Charizard" or "YUGIOH")
  targetName   String
  // "HINT" = inject helpful text into AI prompt
  // "FORCE_DISAMBIGUATION" = skip visual comparison entirely, go straight to user selection
  ruleType     String   @default("HINT")
  // The hint text to inject into the AI system prompt
  content      String
  // How many times the AI failed on this card before the rule was created
  failureCount Int      @default(0)
  // How many times this rule has been used in a scan
  timesApplied Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([targetName])
  @@index([targetName])
  @@map("ai_learning_rules")
}

// ─── Card Fingerprint Index (Scanner V2 · M1) ───────────────────────
// One row per printing = the visual fingerprint of a single Pokémon TCG card
// image, keyed by the Pokémon TCG API card id. Populated offline by a batch
// script (not the scan path). Read at scan time as *evidence*, never as the
// final judge — the truth boundary and set/CN OCR still decide (see AGENTS.md,
// "AI is a sensor, not the judge").
//
// Staleness is queryable, not enforced: `builtAt` + `embeddingModel` +
// `sourceUpdatedAt` let a rebuild target only stale/changed rows. A missing or
// stale fingerprint is low-risk — the pipeline degrades to the current live
// path, it never tells a collector a real card doesn't exist.
//
// pHash (bit(64)) and embedding (vector(512)) are pgvector column types Prisma
// 5.x cannot express natively, so they are Unsupported(...) — written/read via
// raw SQL. Their HNSW indexes are created by raw SQL outside this schema (see
// docs/scanner-v2/M1-investigation.md §3); db push does not manage them.

model CardFingerprint {
  id              String   @id @default(cuid())

  // Identity — the join key back to the live catalog / persisted Card.
  externalId      String   @unique            // Pokémon TCG API card id, e.g. "sv3-125"
  game            String   @default("POKEMON")
  setCode         String?                      // set.ptcgoCode ("SV3") or set.id fallback
  collectorNumber String?                      // card.number

  // Provenance of the pixels this fingerprint was computed from.
  imageUrl        String                       // exact source image (images.large)
  sourceUpdatedAt DateTime?                    // set.updatedAt at build time (change detection)

  // Fingerprints.
  pHash           Unsupported("bit(64)")?
  embedding       Unsupported("vector(512)")?

  // Staleness / reproducibility.
  embeddingModel  String   @default("mobileclip_s2")
  builtAt         DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([game, setCode, collectorNumber])
  @@map("card_fingerprints")
}

// ─── Local card catalog (Scanner V2 · M-CATALOG) ────────────────────────────
// Our own copy of the Pokémon card catalog, so candidate generation and the
// selection re-fetch no longer depend on api.pokemontcg.io being up (see
// docs/scanner-v2/M-CATALOG-investigation.md). Columns are exactly the fields
// formatPokemonCard() produces, so a catalog row maps 1:1 to a CandidatePrinting.
//
// externalId is the shared join key across CatalogCard, CardFingerprint, and
// Card. This table is REFERENCE data — read-only from the app's perspective and
// populated by scripts/build-catalog.mjs; it deliberately carries none of Card's
// user relations, which is why it is a separate table and not an extension of
// Card. Unlike CardFingerprint it uses only native column types, so it is fully
// expressible here and read through the typed Prisma client (no raw SQL).
//
// Every field except the price group is static. Prices are seeded at import and
// refreshed by the M5 cron; a null/stale price never fails a scan (truth boundary).
model CatalogCard {
  id              String   @id @default(cuid())

  externalId      String   @unique            // Pokémon TCG API card id, e.g. "sv3-125"
  game            String   @default("POKEMON")

  // Static identity/resolution fields (formatPokemonCard output).
  name            String
  setName         String
  setCode         String?                      // set.ptcgoCode ("SV3") or set.id fallback
  setPrintedSize  Int?                         // set.printedTotal ("/197")
  collectorNumber String?                      // card.number
  rarity          String   @default("Common")
  imageUrl        String?                      // images.large || images.small
  thumbnailUrl    String?                      // images.small

  // Live price group — seeded at import, owned by the M5 refresh cron.
  marketPrice     Float?
  lowPrice        Float?
  midPrice        Float?
  highPrice       Float?
  priceUpdatedAt  DateTime?

  // Provenance / staleness for sync (mirrors CardFingerprint.sourceUpdatedAt).
  sourceUpdatedAt DateTime?                    // set.updatedAt at import
  importedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([game, setCode, collectorNumber])   // set/CN candidate lookup
  @@index([game, name])                        // name candidate lookup
  @@map("catalog_cards")
}
